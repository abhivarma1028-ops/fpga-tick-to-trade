# ITCH data files — multi-GB, never commit
data/*.bin
data/*.gz
data/*.txt

# Vivado project + synthesis artifacts (machine-specific, regenerated by
# build/synth.tcl). The whole Vivado/ working dir is excluded; keep the
# reproducible inputs (rtl/top.xdc, build/synth.tcl).
Vivado/
build/*.dcp
build/*.bit
build/*.rpt
build/*.log
build/*.jou
*.jou
*.log
*.str
*.dcp
*.bit
*.ltx
*.xpr
**/.Xil/

# cocotb / sim
sim/__pycache__/
sim/results.xml
sim/transcript
sim/dump.fst
sim/dump.vcd
sim/*.wlf
sim/questa_run/
sim/verilator_run/
sim/sim_build/

# QuestaSim native-TB build artifacts (keep the .sv and .do sources)
sim/sv_tb/work/
sim/sv_tb/transcript
sim/sv_tb/modelsim.ini
sim/sv_tb/*.wlf
sim/sv_tb/vsim.wlf

# LaTeX intermediates (keep .tex and .pdf)
docs/*.aux
docs/*.out
docs/*.toc

# Local Claude Code config (not part of the project)
.claude/

# QuestaSim generated default config (Mentor proprietary; regenerated by vmap)
sim/modelsim.ini

# Python
__pycache__/
*.pyc
*.pyo
.venv/
cocotb-env/

# Overlay / bitstream (generated)
overlay/*.bit
overlay/*.hwh

# Jupyter checkpoints
.ipynb_checkpoints/
